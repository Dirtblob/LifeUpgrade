MONGODB_URI="mongodb://localhost:27017/lifeupgrade"
MONGODB_DB_NAME="lifeupgrade"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
DEV_USER_ID="dev-user"
CRON_SECRET="replace-me"

# Best Buy Products API — used for server-side dropdown product discovery AND
# as a live pricing provider (fallback when PricesAPI quota is exhausted).
# MongoDB device_catalog remains the source for rated/recommendable devices.
BESTBUY_API_KEY=
BESTBUY_API_BASE_URL=https://api.bestbuy.com/v1

# AVAILABILITY_PROVIDER controls which provider is used for batch availability.
# Options: pricesapi | bestbuy | mock | none
AVAILABILITY_PROVIDER=bestbuy

# PricesAPI is only for explicit live deal checking; do not remove this path.
PRICES_API_BASE_URL=https://api.pricesapi.io
PRICES_API_KEY=
PRICES_API_COUNTRY=us
AUTO_REFRESH_TOP_RECOMMENDATION_PRICE=false

# eBay Browse API can be added later when approved.
GEMINI_API_KEY=
GEMINI_MODEL=gemma-3-12b-it
GEMINI_DAILY_SOFT_CAP=200
GEMINI_TIMEOUT_MS=45000
